# Runtime summary
def _rt_summary(src):
    if src.empty:
        return pd.DataFrame()
    g = src.groupby(["PartNumber", "OperationNumber"])
    base = g["RuntimeMinutes"].agg(
        Count="count", Median="median", Mean="mean",
        Std="std", Min="min", Max="max"
    ).reset_index()
    tm  = g["RuntimeMinutes"].apply(trimmed_mean).reset_index()
    tm.columns  = ["PartNumber", "OperationNumber", "TrimMean"]
    p95 = g["RuntimeMinutes"].quantile(0.95).reset_index()
    p95.columns = ["PartNumber", "OperationNumber", "P95"]
    out = base.merge(tm, on=["PartNumber", "OperationNumber"])
    out = out.merge(p95, on=["PartNumber", "OperationNumber"])
    for c in ["Median", "Mean", "TrimMean", "Std", "Min", "Max", "P95"]:
        out[c] = out[c].apply(fmt)
    return out.rename(columns={"TrimMean": "Trimmed Mean"})

rt_summary = _rt_summary(df)

# Downtime summary
def _dt_summary(src):
