REQUIRED = [
    "ID", "MachineName", "OrderNumber", "SerialNumber",
    "OperationNumber", "PartNumber", "RuntimeHHMM", "DowntimeHHMM",
    "StartDate", "StartTime", "PlannedEndDate", "PlannedEndTime",
]


def normalize_operation_number(series: pd.Series) -> pd.Series:
    """Normalize operation numbers to zero-padded four-character strings."""
    out = series.astype("string").str.strip()
    out = out.replace({"": pd.NA, "<NA>": pd.NA, "nan": pd.NA, "None": pd.NA})
    return out.str.zfill(4)


BENCHMARK_REQUIRED = ["PartNumber", "OperationNumber"]
BENCHMARK_OPTIONAL = [
    "Family", "OperatorTime_min", "ProductionTime_min", "Notes",
    "OperatorTime_HHMM", "ProductionTime_HHMM",
]
BENCHMARK_COLUMNS = [
    "PartNumber", "OperationNumber", "Family",
    "OperatorTime_min", "ProductionTime_min", "Notes",
]


@st.cache_data(show_spinner=False)
def load_benchmark_csv(data: bytes) -> tuple[pd.DataFrame | None, str | None]:
    """Parse and validate uploaded benchmark CSV into canonical benchmark columns."""
    try:
        raw = pd.read_csv(io.BytesIO(data), encoding="utf-8-sig", dtype=str)
    except Exception as e:
        return None, f"Could not read benchmark CSV: {e}"

    raw.columns = [c.strip() for c in raw.columns]
    missing = [c for c in BENCHMARK_REQUIRED if c not in raw.columns]
    if missing:
        recognized = ", ".join(BENCHMARK_REQUIRED + BENCHMARK_OPTIONAL)
        return None, (
            "Benchmark CSV is missing required columns: "
            f"{', '.join(missing)}. Recognized columns: {recognized}."
        )

    df = raw.copy()
    for c in df.columns:
        if df[c].dtype == object:
            df[c] = df[c].str.strip()

    invalid = []
    for col in BENCHMARK_REQUIRED:
        if df[col].isna().all() or (df[col] == "").all():
            invalid.append(f"{col} has no usable values")
    if invalid:
        return None, "Benchmark CSV has invalid required data: " + "; ".join(invalid) + "."

    df["PartNumber"] = df["PartNumber"].astype("string").str.strip()
    df["OperationNumber"] = normalize_operation_number(df["OperationNumber"])

    if df["PartNumber"].isna().any() or df["OperationNumber"].isna().any():
        bad_rows = sorted(df.index[df["PartNumber"].isna() | df["OperationNumber"].isna()].tolist())
        preview = ", ".join(str(i + 2) for i in bad_rows[:5])
        suffix = "..." if len(bad_rows) > 5 else ""
        return None, (
            "Benchmark CSV has blank or invalid PartNumber/OperationNumber values "
            f"in row(s): {preview}{suffix}."
        )

    hhmm_to_minutes = {
        "OperatorTime_HHMM": "OperatorTime_min",
        "ProductionTime_HHMM": "ProductionTime_min",
    }
    invalid_time_messages = []
    for source_col, target_col in hhmm_to_minutes.items():
        if source_col not in df.columns:
            continue
        parsed = df[source_col].apply(parse_user_time)
        nonblank = df[source_col].notna() & (df[source_col] != "")
        invalid_rows = df.index[nonblank & parsed.isna()].tolist()
        if invalid_rows:
            preview = ", ".join(str(i + 2) for i in invalid_rows[:5])
            suffix = "..." if len(invalid_rows) > 5 else ""
            invalid_time_messages.append(f"{source_col} has invalid values in row(s): {preview}{suffix}")
        df[target_col] = parsed

    if invalid_time_messages:
        return None, "Benchmark CSV has invalid time values: " + "; ".join(invalid_time_messages) + "."

    for col in ["OperatorTime_min", "ProductionTime_min"]:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")
        else:
            df[col] = np.nan

    for col in ["Family", "Notes"]:
        if col not in df.columns:
            df[col] = pd.NA

    df = df[BENCHMARK_COLUMNS].copy()
    df = df.drop_duplicates(subset=["PartNumber", "OperationNumber"], keep="last").reset_index(drop=True)
    return df, None


@st.cache_data(show_spinner=False)
def load_csv(data: bytes):
    """
    Parse WinCC semicolon CSV.
    Returns (df_clean, df_raw, quality_dict) or (None, None, {"error": msg}).
    """
    try:
        raw = pd.read_csv(io.BytesIO(data), sep=";", encoding="utf-8-sig", dtype=str)
    except Exception as e:
        return None, None, {"error": str(e)}

    raw.columns = [c.strip() for c in raw.columns]
    missing = [c for c in REQUIRED if c not in raw.columns]
    if missing:
        return None, None, {"error": f"Missing columns: {missing}"}

    df = raw.copy()
    for c in df.columns:
        if df[c].dtype == object:
            df[c] = df[c].str.strip()

    df["ID"] = pd.to_numeric(df["ID"], errors="coerce")
    df["OperationNumber"] = normalize_operation_number(df["OperationNumber"])

    df["RuntimeMinutes"]  = df["RuntimeHHMM"].apply(parse_hhmm)
    df["DowntimeMinutes"] = df["DowntimeHHMM"].apply(parse_hhmm)
    df["RuntimeHours"]    = df["RuntimeMinutes"] / 60
    df["DowntimeHours"]   = df["DowntimeMinutes"] / 60
    df["Rt_disp"]  = df["RuntimeMinutes"].apply(fmt)
    df["Dt_disp"]  = df["DowntimeMinutes"].apply(fmt)

    def _dt(dcol, tcol):
        return pd.to_datetime(df[dcol] + " " + df[tcol],
                              format="%d/%m/%Y %H:%M", errors="coerce")

    df["StartDT"]   = _dt("StartDate", "StartTime")
    df["PlannedDT"] = _dt("PlannedEndDate", "PlannedEndTime")

    dup_cols = ["MachineName", "OrderNumber", "SerialNumber",
                "OperationNumber", "PartNumber", "StartDate", "StartTime"]
    df["_dup"] = df.duplicated(subset=dup_cols, keep=False)

    quality = {
        "total":           len(df),
        "dup":             int(df["_dup"].sum()),
        "bad_rt":          int(df["RuntimeMinutes"].isna().sum()),
        "zero_rt":         int((df["RuntimeMinutes"] == 0).sum()),
        "bad_dt":          int(df["DowntimeMinutes"].isna().sum()),
        "bad_start":       int(df["StartDT"].isna().sum()),
        "missing_by_col":  {c: int(df[c].isna().sum()) for c in REQUIRED},
    }
    return df, raw, quality


@st.cache_data(show_spinner=False)
def build_runtime_summary(src: pd.DataFrame, trim_pct: float) -> pd.DataFrame:
    """Build the runtime summary table for the current filtered dataset."""
    if src.empty:
        return pd.DataFrame()
    g = src.groupby(["PartNumber", "OperationNumber"])
    base = g["RuntimeMinutes"].agg(
        Count="count", Median="median", Mean="mean",
        Std="std", Min="min", Max="max"
    ).reset_index()
    tm = g["RuntimeMinutes"].apply(lambda s: trimmed_mean(s, trim_pct)).reset_index(name="TrimMean")
    p95 = g["RuntimeMinutes"].quantile(0.95).reset_index(name="P95")
    return base.merge(tm, on=["PartNumber", "OperationNumber"]).merge(
        p95,
        on=["PartNumber", "OperationNumber"],
    )


@st.cache_data(show_spinner=False)
def build_downtime_summary(src: pd.DataFrame) -> pd.DataFrame:
    """Build the downtime summary table for the current filtered dataset."""
    if src.empty:
        return pd.DataFrame()
    return src.groupby(["PartNumber", "OperationNumber"])["DowntimeMinutes"].agg(
        Count="count", Median="median", Mean="mean", Max="max"
    ).reset_index()


@st.cache_data(show_spinner=False)
def build_machine_summary(src: pd.DataFrame) -> pd.DataFrame:
    """Build machine-level runtime and downtime aggregates."""
    if src.empty:
        return pd.DataFrame()
    return src.groupby("MachineName").agg(
        Rows=("ID", "count"),
        MedianRuntime=("RuntimeMinutes", "median"),
        TotalDowntimeMin=("DowntimeMinutes", "sum"),
    ).reset_index()


@st.cache_data(show_spinner=False)
def build_benchmark_comparison(
    src: pd.DataFrame,
    benchmark_records: tuple[tuple[object, ...], ...],
    trim_pct: float,
) -> tuple[pd.DataFrame, pd.DataFrame]:
    """Build raw WinCC aggregates plus benchmark comparison data."""
    wincc_agg = pd.DataFrame()
    bm_comparison = pd.DataFrame()
    if src.empty:
        return wincc_agg, bm_comparison

    g = src.groupby(["PartNumber", "OperationNumber"])
    wincc_agg = g["RuntimeMinutes"].agg(
        WinCC_Count="count", WinCC_Median="median", WinCC_Mean="mean"
    ).reset_index()
    tm_s = g["RuntimeMinutes"].apply(lambda s: trimmed_mean(s, trim_pct)).reset_index(name="WinCC_TrimMean")
    wincc_agg = wincc_agg.merge(tm_s, on=["PartNumber", "OperationNumber"])

    benchmark_df = _records_to_df(BENCHMARK_COLUMNS, benchmark_records)
    if benchmark_df.empty:
        bm_comparison = wincc_agg.copy()
        for c in ["OperatorTime_min", "ProductionTime_min", "Family", "Notes"]:
            bm_comparison[c] = np.nan
    else:
        bm_comparison = wincc_agg.merge(
            benchmark_df[["PartNumber", "OperationNumber", "Family", "OperatorTime_min", "ProductionTime_min", "Notes"]],
            on=["PartNumber", "OperationNumber"], how="outer",
        )
    return wincc_agg, bm_comparison


@st.cache_data(show_spinner=False)
def build_comparison_display(cmp: pd.DataFrame, trim_label: str) -> pd.DataFrame:
    """Build the formatted benchmark comparison table."""
    if cmp.empty:
        return pd.DataFrame()
    rows = []
    for _, r in cmp.iterrows():
        med = r.get("WinCC_Median")
        op_t = r.get("OperatorTime_min")
        pr_t = r.get("ProductionTime_min")
        row = {
            "Part": r.get("PartNumber", ""),
            "Op": r.get("OperationNumber", ""),
            "Count": int(r["WinCC_Count"]) if pd.notna(r.get("WinCC_Count")) else "",
            "WinCC Median": fmt(med),
            "WinCC Mean": fmt(r.get("WinCC_Mean")),
            trim_label: fmt(r.get("WinCC_TrimMean")),
            "Operator Time": fmt(op_t),
            "Prod. Time": fmt(pr_t),
        }
        if pd.notna(med) and pd.notna(op_t) and float(op_t) != 0:
            d = float(med) - float(op_t)
            row["Δ vs Operator"] = fmt(abs(d)) + (" ↑" if d > 0 else " ↓")
            row["% vs Operator"] = f"{d / float(op_t) * 100:+.1f}%"
        else:
            row["Δ vs Operator"] = "—"
            row["% vs Operator"] = "—"
        if pd.notna(med) and pd.notna(pr_t) and float(pr_t) != 0:
            d2 = float(med) - float(pr_t)
            row["Δ vs Prod."] = fmt(abs(d2)) + (" ↑" if d2 > 0 else " ↓")
        else:
            row["Δ vs Prod."] = "—"
        rows.append(row)
    return pd.DataFrame(rows)


@st.cache_data(show_spinner=False)
def build_cached_views(
    df_full: pd.DataFrame,
    date_from_iso: str,
    date_to_iso: str,
    machines: tuple[str, ...],
    parts: tuple[str, ...],
    operations: tuple[str, ...],
    serial_filter: str,
    order_filter: str,
    exclude_missing_runtime: bool,
    exclude_zero_runtime: bool,
    exclude_duplicates: bool,
    outlier_mode: str,
    outlier_trim_pct: float | None,
    min_runtime: float | None,
    max_runtime: float | None,
    benchmark_records: tuple[tuple[object, ...], ...],
    trim_pct: float,
    trim_label: str,
) -> dict[str, pd.DataFrame | dict]:
    """Build the cached filtered dataset and its derived report tables."""
    df = df_full.copy()
    date_from = pd.to_datetime(date_from_iso).date()
    date_to = pd.to_datetime(date_to_iso).date()
    df = df[(df["StartDT"].dt.date >= date_from) & (df["StartDT"].dt.date <= date_to)]
    if machines:
        df = df[df["MachineName"].isin(machines)]
    if parts:
        df = df[df["PartNumber"].isin(parts)]
    if operations:
        df = df[df["OperationNumber"].isin(operations)]
    if serial_filter:
        df = df[df["SerialNumber"].str.contains(serial_filter, na=False, case=False)]
    if order_filter:
        df = df[df["OrderNumber"].str.contains(order_filter, na=False, case=False)]
    if exclude_missing_runtime:
        df = df[df["RuntimeMinutes"].notna()]
    if exclude_zero_runtime:
        df = df[df["RuntimeMinutes"] != 0]
    if exclude_duplicates:
        df = df[~df["_dup"]]

    df, df_excl, out_info = apply_outliers(
        df,
        "RuntimeMinutes",
        outlier_mode,
        min_value=min_runtime,
        max_value=max_runtime,
        trim_pct=outlier_trim_pct,
    )

    df_export = df[ECOLS].rename(columns={"Rt_disp": "Runtime_HHMM", "Dt_disp": "Downtime_HHMM"})
    df_excl_exp = (
        df_excl[ECOLS].rename(columns={"Rt_disp": "Runtime_HHMM", "Dt_disp": "Downtime_HHMM"})
        if not df_excl.empty else pd.DataFrame(columns=ECOLS)
    )

    rt_summary_raw = build_runtime_summary(df, trim_pct)
    rt_summary = rt_summary_raw.copy()
    if not rt_summary.empty:
        for c in ["Median", "Mean", "TrimMean", "Std", "Min", "Max", "P95"]:
            rt_summary[c] = rt_summary[c].apply(fmt)
        rt_summary = rt_summary.rename(columns={"TrimMean": trim_label})

    dt_summary_raw = build_downtime_summary(df)
    dt_summary = dt_summary_raw.copy()
    if not dt_summary.empty:
        for c in ["Median", "Mean", "Max"]:
            dt_summary[c] = dt_summary[c].apply(fmt)

    machine_summary_raw = build_machine_summary(df)
    mach_summary = machine_summary_raw.copy()
    if not mach_summary.empty:
        mach_summary["Median Runtime"] = mach_summary["MedianRuntime"].apply(fmt)
        mach_summary["Total Downtime"] = mach_summary["TotalDowntimeMin"].apply(fmt)
        mach_summary = mach_summary.drop(columns=["MedianRuntime", "TotalDowntimeMin"])

