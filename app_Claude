with t_pc:
    st.subheader("Period-over-Period Comparison")
    vd = df_full["StartDT"].dropna()
    if vd.empty:
        st.warning("No valid start dates in the dataset.")
    else:
        mn2, mx2 = vd.min().date(), vd.max().date()
        mid = mn2 + (mx2 - mn2) // 2

        c1, c2 = st.columns(2)
        with c1:
            st.markdown("**Period A**")
            pa_f = st.date_input("From", value=mn2, key="pa_f", min_value=mn2, max_value=mx2)
            pa_t = st.date_input("To",   value=mid, key="pa_t", min_value=mn2, max_value=mx2)
        with c2:
            st.markdown("**Period B**")
            pb_f = st.date_input("From", value=mid, key="pb_f", min_value=mn2, max_value=mx2)
            pb_t = st.date_input("To",   value=mx2, key="pb_t", min_value=mn2, max_value=mx2)

        def _slice(f, t):
            return df_full[
                (df_full["StartDT"].dt.date >= f) &
                (df_full["StartDT"].dt.date <= t) &
                df_full["RuntimeMinutes"].notna() &
                (df_full["RuntimeMinutes"] > 0)
            ]

        dfa = _slice(pa_f, pa_t)
        dfb = _slice(pb_f, pb_t)

        def _row(d, lbl):
            r  = d["RuntimeMinutes"]
            dw = d["DowntimeMinutes"].fillna(0)
            return {
                "Period": lbl,
                "Rows": len(d),
                "Unique Parts": d["PartNumber"].nunique(),
                "Median Runtime":  fmt(r.median()),
                "Mean Runtime":    fmt(r.mean()),
                "Trim Mean":       fmt(trimmed_mean(r)),
                "P95 Runtime":     fmt(r.quantile(0.95)) if len(r) else "—",
                "Std Dev":         fmt(r.std()),
                "Median Downtime": fmt(dw.median()),
                "Max Downtime":    fmt(dw.max()),
            }

        cmp_tbl = pd.DataFrame([
            _row(dfa, f"A  ({pa_f} → {pa_t})"),
            _row(dfb, f"B  ({pb_f} → {pb_t})"),
        ]).set_index("Period").T
        st.dataframe(cmp_tbl, use_container_width=True)

        if not dfa.empty and not dfb.empty:
            ma = dfa["RuntimeMinutes"].median()
            mb = dfb["RuntimeMinutes"].median()
            delta = mb - ma
            pct_d = delta / ma * 100 if ma else 0
            st.metric("Median Runtime  A → B", fmt(mb),
                      delta=f"{'+' if delta >= 0 else ''}{fmt(abs(delta))} ({pct_d:+.1f}%)")

            dfa2 = dfa.copy(); dfa2["Period"] = "A"
            dfb2 = dfb.copy(); dfb2["Period"] = "B"
            ab = pd.concat([dfa2, dfb2])
            ab_g = ab.groupby(["PartNumber", "Period"])["RuntimeHours"].median().reset_index()
            fig_p = px.bar(ab_g, x="PartNumber", y="RuntimeHours", color="Period",
                           barmode="group", template=THEME,
                           labels={"RuntimeHours": "Median Runtime (h)"}, height=360)
            fig_p.update_xaxes(tickangle=-40)
            fig_p.update_layout(margin=dict(t=5, b=80))
            st.plotly_chart(fig_p, use_container_width=True)

            ma_g = dfa.groupby(["PartNumber", "OperationNumber"])["RuntimeMinutes"].median()
            mb_g = dfb.groupby(["PartNumber", "OperationNumber"])["RuntimeMinutes"].median()
            chg = pd.DataFrame({"Period A": ma_g, "Period B": mb_g}).reset_index()
            chg["Δ"]   = chg["Period B"] - chg["Period A"]
            chg["Δ %"] = (chg["Δ"] / chg["Period A"] * 100).round(1)
            for c in ["Period A", "Period B", "Δ"]:
                chg[c] = chg[c].apply(lambda x: fmt(x) if pd.notna(x) else "—")
            chg["Δ %"] = chg["Δ %"].apply(lambda x: f"{x:+.1f}%" if pd.notna(x) else "—")
            st.subheader("Median Runtime Change – Part × Operation")
            st.dataframe(chg, use_container_width=True, hide_index=True)

