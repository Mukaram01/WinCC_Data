"""
WinCC Production Analytics Dashboard
=====================================
Thin Streamlit entrypoint.
"""

import warnings

import streamlit as st

from src.analytics import build_cached_views, trimmed_mean_label
from src.constants import BENCHMARK_COLUMNS
from src.data import load_csv
from src.state import _init, ensure_filter_defaults, filter_defaults, reset_filters
from src.ui_utils import df_to_records
from src.views import benchmark, downtime, export, groups, overview, period_compare, quality as quality_view, runtime

warnings.filterwarnings("ignore")

st.set_page_config(
    page_title="WinCC Production Analytics",
    page_icon="🏭",
    layout="wide",
    initial_sidebar_state="expanded",
)

st.markdown(
    """
    <style>
    [data-testid="stMetric"] {
        background: #1e1e2e; border: 1px solid #313244;
        border-radius: 10px; padding: 12px 16px;
    }
    [data-testid="stMetricLabel"] { font-size: 0.78rem; color: #a6adc8; }
    [data-testid="stMetricValue"] { font-size: 1.4rem; font-weight: 700; color: #cba6f7; }
    hr { border-color: #313244; }
    </style>
    """,
    unsafe_allow_html=True,
)

_init()

st.title("🏭 WinCC Production Analytics Dashboard")
uploaded = st.file_uploader(
    "Upload WinCC CSV export (semicolon-delimited, European dates DD/MM/YYYY)",
    type=["csv", "txt"],
)

if uploaded is None:
    st.info("👆 Upload a WinCC CSV file to begin.")
    st.stop()

file_key = f"{uploaded.name}_{uploaded.size}"
if st.session_state.get("_file_key") != file_key:
    st.session_state["_raw_bytes"] = uploaded.read()
    st.session_state["_file_key"] = file_key

with st.spinner("Parsing and cleaning data …"):
    df_full, df_raw, quality_info = load_csv(st.session_state["_raw_bytes"])

if df_full is None:
    st.error(f"❌ Could not parse file: {quality_info.get('error')}")
    st.stop()

ensure_filter_defaults(df_full)
defaults = filter_defaults(df_full)

with st.sidebar:
    st.header("🔧 Filters & Options")
    min_date = defaults["filter_from"]
    max_date = defaults["filter_to"]

    st.subheader("📅 Date Range")
    date_from = st.date_input("From", value=defaults["filter_from"], min_value=min_date, max_value=max_date, key="filter_from")
    date_to = st.date_input("To", value=defaults["filter_to"], min_value=min_date, max_value=max_date, key="filter_to")

    st.subheader("🏗 Machine / Part / Operation")
    machines = st.multiselect("Machine", defaults["filter_machine"], default=defaults["filter_machine"], key="filter_machine")
    parts = st.multiselect("Part Number", defaults["filter_part"], default=defaults["filter_part"], key="filter_part")
    operations = st.multiselect("Operation", defaults["filter_operation"], default=defaults["filter_operation"], key="filter_operation")

    st.subheader("🔍 Text Search")
    serial_filter = st.text_input("Serial (contains)", defaults["filter_serial"], key="filter_serial")
    order_filter = st.text_input("Order (contains)", defaults["filter_order"], key="filter_order")

    st.subheader("🧹 Cleaning")
    exclude_missing_runtime = st.checkbox("Exclude missing runtime", value=defaults["filter_exclude_missing_runtime"], key="filter_exclude_missing_runtime")
    exclude_zero_runtime = st.checkbox("Exclude zero runtime", value=defaults["filter_exclude_zero_runtime"], key="filter_exclude_zero_runtime")
    exclude_duplicates = st.checkbox("Exclude duplicates", value=defaults["filter_exclude_duplicates"], key="filter_exclude_duplicates")

    st.subheader("📊 Outlier Removal")
    selected_trim_pct = st.slider("Trimmed-mean percentage", min_value=0.0, max_value=25.0, value=10.0, step=0.5, help="Controls every trimmed-mean calculation and related label across the dashboard.") / 100.0
    modes = ["None", "Mild (IQR x3)", "Aggressive (IQR x1.5 + P2-P98)"]
    outlier_mode_type = st.radio("Outlier filter type", ["Preset rules", "Custom bounds"], index=0, horizontal=True)
    outlier_mode = st.selectbox("Runtime outlier mode", modes, index=modes.index(defaults["filter_outlier_mode"]), key="filter_outlier_mode")

    custom_trim_pct = None
    custom_min_runtime = None
    custom_max_runtime = None
    if outlier_mode_type == "Custom bounds":
        custom_trim_pct = st.number_input("Trim threshold percent", min_value=0.0, max_value=49.0, value=0.0, step=0.5, help="Use either a percentage (10 for 10%) or a decimal fraction (0.10 for 10%).")
        custom_min_runtime = st.number_input("Minimum runtime bound (minutes)", min_value=0.0, value=0.0, step=1.0)
        custom_max_runtime = st.number_input("Maximum runtime bound (minutes)", min_value=0.0, value=float(max(1.0, df_full["RuntimeMinutes"].dropna().max() if not df_full["RuntimeMinutes"].dropna().empty else 1.0)), step=1.0)

    if st.button("🔄 Reset Filters"):
        reset_filters(df_full)
        st.rerun()

active_outlier_mode = outlier_mode if outlier_mode_type == "Preset rules" else "Custom bounds"
active_trim_pct = custom_trim_pct if outlier_mode_type == "Custom bounds" else None
active_min_runtime = custom_min_runtime if outlier_mode_type == "Custom bounds" else None
active_max_runtime = custom_max_runtime if outlier_mode_type == "Custom bounds" else None
trimmed_mean_name = trimmed_mean_label(selected_trim_pct)
trim_mean_name = trimmed_mean_label(selected_trim_pct, short=True)
benchmark_records = df_to_records(st.session_state.benchmarks[BENCHMARK_COLUMNS].copy())

cached_views = build_cached_views(
    df_full,
    date_from.isoformat(),
    date_to.isoformat(),
    tuple(machines),
    tuple(parts),
    tuple(operations),
    serial_filter,
    order_filter,
    exclude_missing_runtime,
    exclude_zero_runtime,
    exclude_duplicates,
    active_outlier_mode,
    active_trim_pct,
    active_min_runtime,
    active_max_runtime,
    benchmark_records,
    selected_trim_pct,
    trimmed_mean_name,
)

tabs = st.tabs(["📊 Overview", "🧹 Data Quality", "⏱ Runtime", "⏸ Downtime", "🎯 Benchmark", "👨‍👩‍👧 Groups", "📅 Period Compare", "💾 Export"])

with tabs[0]:
    overview.render(cached_views["df"], cached_views["out_info"], selected_trim_pct, trim_mean_name)
with tabs[1]:
    quality_view.render(cached_views["df"], cached_views["df_excl"], df_full, cached_views["out_info"], quality_info)
with tabs[2]:
    runtime.render(cached_views["df"], cached_views["rt_summary"], selected_trim_pct, trimmed_mean_name)
with tabs[3]:
    downtime.render(cached_views["df"], cached_views["dt_summary"])
with tabs[4]:
    benchmark.render(df_full, cached_views["bm_comparison"], cached_views["cmp_display"], trim_mean_name, selected_trim_pct, st.session_state)
with tabs[5]:
    groups.render(cached_views["df"], df_full, st.session_state)
with tabs[6]:
    period_compare.render(df_full, selected_trim_pct, trimmed_mean_name)
with tabs[7]:
    export.render(cached_views["df_export"], cached_views["df_excl_exp"], cached_views["rt_summary"], cached_views["dt_summary"], cached_views["mach_summary"], cached_views["cmp_display"], st.session_state.benchmarks.copy(), trimmed_mean_name)
